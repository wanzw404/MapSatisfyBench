# =============================================================================
# 环境变量配置文件
# =============================================================================
# 该文件定义了App相关的环境变量，会在app/config/env.py执行load_dotenv时被读取
# =============================================================================
# ==================== Models ====================
# 调用模型时的BASE_URL (必填)
BASE_URL_USER=
BASE_URL=

# API Token (必填)
AI_STUDIO_TOKEN_USER=
AI_STUDIO_TOKEN=

# 使用的模型名称
MODEL_NAME=gpt-5.3-chat-0303-global

# ==================== Embedding Models ====================
# embedding模型参数
EMBEDDING_MODEL_URL=
EMBEDDING_MODEL_NAME=text-embedding-v2
EMBEDDING_DIMENSIONS=1536
EMBEDDING_ENCODING_FORMAT=float